<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@id/exo_controls_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="4dp">

        <ImageButton
            android:id="@+id/odysee_player_settings_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:src="@drawable/exo_ic_settings"
            android:contentDescription="Player settings" />

        <TextView
            android:id="@+id/odysee_hd_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:text="HD"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="9sp"
            android:background="#FFE50054"
            android:paddingHorizontal="4dp"
            android:paddingVertical="1dp"
            android:visibility="gone" />
    </FrameLayout>


    <LinearLayout
        android:id="@id/exo_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@id/exo_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:paddingHorizontal="4dp" />

        <com.odysee.app.player.GradientTimeBar
            android:id="@id/exo_progress"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1" />

        <TextView
            android:id="@id/exo_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:paddingHorizontal="4dp" />

        <LinearLayout
            android:id="@+id/odysee_live_button"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical|start"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:background="?android:attr/selectableItemBackground"
            android:visibility="gone">

            <View
                android:id="@+id/odysee_live_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/odysee_live_dot" />

            <TextView
                android:id="@+id/odysee_live_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="LIVE"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/odysee_player_pip_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:src="@drawable/ic_pip"
            android:contentDescription="Picture in picture" />

        <ImageButton
            android:id="@id/exo_fullscreen"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:src="@drawable/exo_ic_fullscreen_enter"
            android:contentDescription="Fullscreen" />
    </LinearLayout>
</FrameLayout>
