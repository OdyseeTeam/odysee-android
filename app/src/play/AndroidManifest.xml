<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <service
            android:name="com.odysee.app.notifications.OdyseeFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Defaults applied to FCM-delivered system notifications that don't
             explicitly set their own icon/color (the OS uses these as fallbacks). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_odysee" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/odysee_pink" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="odysee_notifications" />

        <!-- Chromecast options provider, loaded by the Cast SDK to configure
             the receiver app id + notification target. -->
        <meta-data
            android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
            android:value="com.odysee.app.cast.CastOptionsProvider" />
    </application>

</manifest>
